<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExerciseTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">ExerciseTracker</a>
                <div class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        <a class="nav-link" asp-controller="Exercise" asp-action="Index">Ejercicio</a>
                        <a class="nav-link" asp-controller="Goal" asp-action="Index">Metas</a>
                        <a class="nav-link" asp-controller="Stats" asp-action="Index">Estadisticas</a>
                        <a class="nav-link" asp-controller="Notification" asp-action="Index">Recordatorios</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link nav-link">Salir</button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Registro</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
